      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },
    {
      "response_id": "personal_dreams_4",
      "text": "I don't dream of much anymore. Just peace. Quiet days with enough to eat. That's all I want now.",
      "topic_type": 2,
      "personality_affinity": ["weary", "humble"],
      "min_disposition": 35,
      "max_disposition": 100,
      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },

    {
      "response_id": "personal_complaints_wolves",
      "text": "The wolves are getting worse every year. Used to stay in the deep forest. Now they're bold enough to come close to town.",
      "topic_type": 2,
      "personality_affinity": ["frustrated", "worried"],
      "min_disposition": 30,
      "max_disposition": 100,
      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },
    {
      "response_id": "personal_complaints_prices",
      "text": "Prices keep going up, but wages stay the same. How's an honest person supposed to get by?",
      "topic_type": 2,
      "personality_affinity": ["frustrated", "pragmatic"],
      "min_disposition": 30,
      "max_disposition": 100,
      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },
    {
      "response_id": "personal_complaints_roads",
      "text": "The roads are getting worse every year. Used to be you could travel safely. Now it's a gamble every trip.",
      "topic_type": 2,
      "personality_affinity": ["frustrated", "concerned"],
