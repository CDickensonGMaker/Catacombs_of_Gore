      "conditions": []
    },

    {
      "response_id": "personal_generic_1",
      "text": "Not much to tell, really. I live, I work, I sleep. Same as everyone else around here.",
      "topic_type": 2,
      "personality_affinity": ["humble", "plain"],
      "min_disposition": 30,
      "max_disposition": 100,
      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },
    {
      "response_id": "personal_generic_2",
      "text": "Life's hard, but this is home. Can't complain too much. Others have it worse.",
      "topic_type": 2,
      "personality_affinity": ["humble", "accepting"],
      "min_disposition": 30,
      "max_disposition": 100,
      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },
    {
      "response_id": "personal_generic_3",
      "text": "I have my worries like anyone else, but I get by. One day at a time, that's how you do it.",
      "topic_type": 2,
      "personality_affinity": ["pragmatic", "resilient"],
      "min_disposition": 30,
      "max_disposition": 100,
      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },
    {
      "response_id": "personal_generic_4",
      "text": "Family's what matters in the end. Everything else is just noise. As long as they're safe, I'm content.",
      "topic_type": 2,
      "personality_affinity": ["caring", "content"],
      "min_disposition": 35,
      "max_disposition": 100,
      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },
    {
      "response_id": "personal_generic_5",
      "text": "Every day I wake up is a blessing. With all that's out there in the dark, you learn to appreciate the simple things.",
      "topic_type": 2,
      "personality_affinity": ["grateful", "philosophical"],
      "min_disposition": 35,
      "max_disposition": 100,
      "required_knowledge": [],
      "weight": 1.0,
      "actions": [],
      "conditions": []
    },

    {
